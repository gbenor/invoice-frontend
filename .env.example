VITE_API_URL=https://your-railway-backend-url
VITE_API_KEY=optional-default-key
# Optional backend route prefix, for example /api
VITE_API_BASE_PATH=
# Defaults to bearer to match the FastAPI backend Authorization header.
# Other supported values: x-api-key, query, header, none
VITE_API_AUTH_MODE=bearer
VITE_API_AUTH_QUERY_PARAM=api_key
VITE_API_AUTH_HEADER_NAME=x-api-key
VITE_BASE_PATH=/invoice-frontend/
VITE_APP_VERSION=
VITE_BUILD_TIME=
VITE_GIT_SHA=
